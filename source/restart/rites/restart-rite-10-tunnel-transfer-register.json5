{
  "id": "restart-rite-10-tunnel-transfer-register",
  "name": "RESTART 10：隧道换乘登记",
  "description": "救护车驶进无出口隧道后，车厢墙面弹出一台旧医院的换乘登记机。机器要求林夕在“记忆下车”和“通行权下车”之间盖章；第八轮腕带则在登记口里发烫，像是在提醒她：选项会被带到下一轮。",
  "triggers": [
    "restart-eighth-loop-opened"
  ],
  "consequences": [
    "restart-event-11-bed-number-broadcast"
  ],
  "conditions": [
    "flag.restart_eighth_loop_opened:1",
    "have.card:card-restart-linxi",
    "have.card:card-restart-yue",
    "have.card:card-restart-radio"
  ],
  "effects": [
    "set.flag:restart_tunnel_transfer_registered",
    "gain.card:card-restart-eighth-wristband",
    "gain.card:card-restart-memory-ampoule"
  ],
  "slots": [
    {
      "id": "slot-0",
      "name": "负责盖章的人",
      "cardType": "person"
    },
    {
      "id": "slot-1",
      "name": "监听登记机的物件",
      "cardType": "item"
    }
  ],
  "options": [
    {
      "text": "打碎记忆安瓿，让林夕把第八轮来电完整带下车。",
      "effects": [
        {
          "type": "gain.influence",
          "amount": 4
        },
        {
          "type": "set.flag",
          "flag": "restart_saved_linxi_memory_route"
        }
      ]
    },
    {
      "text": "让越医生先盖通行章，保住他进入签名室的权限。",
      "effects": [
        {
          "type": "gain.favor",
          "amount": 4
        },
        {
          "type": "set.flag",
          "flag": "restart_preserved_yue_access_route"
        }
      ]
    }
  ],
  "coinRewardTiers": [
    {
      "minValue": 0,
      "maxValue": 5,
      "rewards": [
        {
          "type": "gain.influence",
          "amount": 1
        }
      ],
      "description": "登记机吞掉半枚章。广播警告：有人将无证下车，下一轮会少一段记忆。"
    },
    {
      "minValue": 6,
      "maxValue": 10,
      "rewards": [
        {
          "type": "gain.favor",
          "amount": 2
        },
        {
          "type": "gain.influence",
          "amount": 2
        }
      ],
      "description": "腕带内侧显出倒置床号。越医生认出那不是病房号，而是旧日出医院的地下签名柜。"
    },
    {
      "minValue": 11,
      "maxValue": 999,
      "rewards": [
        {
          "type": "gain.favor",
          "amount": 3
        },
        {
          "type": "gain.influence",
          "amount": 4
        },
        {
          "type": "set.flag",
          "flag": "restart_transfer_stamp_stabilized"
        }
      ],
      "description": "登记机吐出两枚互相矛盾的章：林夕可带记忆下车，越医生可带债务下车，但签名室会要求补交一个人的死亡。"
    }
  ]
}

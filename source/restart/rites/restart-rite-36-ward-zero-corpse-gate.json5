{
  "id": "restart-rite-36-ward-zero-corpse-gate",
  "name": "RESTART 36：Ward Zero 尸门",
  "description": "活人出院预令带林夕和第七次日出回到旧日出医院最底层。门牌写着 Ward Zero，副标题却是“尸体离院处”：只有已经被医院结算过死亡的人，才允许从这里出去。预令在门缝前发白，像一份还没学会装死的通行证。",
  "triggers": ["restart-living-discharge-order-issued", "restart-ward-zero-return-summons-ready"],
  "consequences": ["restart-event-37-pulse-arrears-toll", "restart-ward-zero-corpse-gate-opened"],
  "conditions": [
    "flag.restart_living_discharge_order_issued:1",
    "flag.restart_next_region_seventh_sun_discharge_route:1",
    "have.card:card-restart-living-discharge-order",
    "have.card:card-restart-seventh-sun",
    "have.card:card-restart-reversed-bed-ledger"
  ],
  "effects": [
    "set.flag:restart_ward_zero_corpse_gate_opened",
    "gain.card:card-restart-ward-zero-doorplate",
    "gain.card:card-restart-temporary-living-pass"
  ],
  "slots": [
    {"id": "slot-0", "name": "递交出院预令的人", "cardType": "person"},
    {"id": "slot-1", "name": "证明活人预令的文件", "cardType": "item"}
  ],
  "options": [
    {
      "text": "把第七次日出的名字写在门牌背面，要求 Ward Zero 按活证人公开受理。",
      "effects": [
        {"type": "gain.influence", "amount": 13},
        {"type": "set.flag", "flag": "restart_seventh_sun_public_discharge_claim"}
      ]
    },
    {
      "text": "把林夕的 B-07/0 倒账压进门缝，让尸门先传唤这个“暂未死亡”的病人。",
      "effects": [
        {"type": "gain.favor", "amount": 13},
        {"type": "set.flag", "flag": "restart_linxi_ward_zero_summons_claim"}
      ]
    }
  ],
  "coinRewardTiers": [
    {"minValue": 0, "maxValue": 8, "rewards": [{"type": "gain.influence", "amount": 2}], "description": "尸门只开到能递进一只手。门牌承认 Ward Zero 存在，却把活人通行证盖成临时。"},
    {"minValue": 9, "maxValue": 14, "rewards": [{"type": "gain.favor", "amount": 4}, {"type": "gain.influence", "amount": 4}], "description": "活人出院预令被门缝吞下又吐回，背面多出一句：通行前请补缴脉搏欠费。"},
    {"minValue": 15, "maxValue": 999, "rewards": [{"type": "gain.favor", "amount": 6}, {"type": "gain.influence", "amount": 6}, {"type": "set.flag", "flag": "restart_ward_zero_gate_route_stabilized"}], "description": "Ward Zero 门牌从墙上松动。它不再只是入口，也是能带走的证据：医院确实设置过只准死人离院的部门。"}
  ]
}

{
  "id": "restart-rite-25-foreman-supply-ledger-coordinate",
  "name": "RESTART 25：供纸账本坐标",
  "description": "无论是工头交出的纸浆配比，还是工人证词纸带背面的复写痕，都指向同一个地方：决定死亡证明供给的账房。塔内播音员说，只要按这串比例反向调频，就能找到它。代价是纸厂会知道林夕已经追到了供纸链下一环。",
  "triggers": [
    "restart-paper-factory-witness-filed"
  ],
  "consequences": [
    "restart-foreman-supply-ledger-coordinate-decoded"
  ],
  "conditions": [
    "flag.restart_foreman_witness_ledger_opened:1",
    "have.card:card-restart-worker-testimony",
    "have.card:card-restart-uncut-certificate-paper"
  ],
  "effects": [
    "set.flag:restart_foreman_supply_ledger_coordinate_decoded"
  ],
  "slots": [
    {
      "id": "slot-0",
      "name": "解码坐标的人",
      "cardType": "person"
    },
    {
      "id": "slot-1",
      "name": "供纸链样纸",
      "cardType": "item"
    }
  ],
  "options": [
    {
      "text": "立刻追踪账房坐标，抢在下一批证明纸送回医院前接管供纸账本。",
      "effects": [
        {
          "type": "gain.influence",
          "amount": 9
        },
        {
          "type": "set.flag",
          "flag": "restart_supply_ledger_pursued_from_testimony"
        }
      ]
    },
    {
      "text": "放任纸厂发现追踪痕迹，把他们的回收账本一起钓出来。",
      "effects": [
        {
          "type": "gain.favor",
          "amount": 9
        },
        {
          "type": "set.flag",
          "flag": "restart_supply_ledger_baited_from_factory"
        }
      ]
    }
  ],
  "coinRewardTiers": [
    {
      "minValue": 0,
      "maxValue": 8,
      "rewards": [
        {
          "type": "gain.influence",
          "amount": 2
        }
      ],
      "description": "坐标解出半截。你知道账房存在，却还不知道它属于医院还是广播塔。"
    },
    {
      "minValue": 9,
      "maxValue": 14,
      "rewards": [
        {
          "type": "gain.favor",
          "amount": 4
        },
        {
          "type": "gain.influence",
          "amount": 4
        }
      ],
      "description": "未裁切证明纸显出账房门牌：所有死亡证明都从同一本供纸账里扣数。"
    },
    {
      "minValue": 15,
      "maxValue": 999,
      "rewards": [
        {
          "type": "gain.favor",
          "amount": 6
        },
        {
          "type": "gain.influence",
          "amount": 6
        }
      ],
      "description": "广播塔和纸厂同时沉默一秒。工头的坐标指向下一处核心：给死亡分配纸额的账房。"
    }
  ]
}

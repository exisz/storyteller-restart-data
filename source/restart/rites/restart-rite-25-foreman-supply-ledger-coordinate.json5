{
  "id": "restart-rite-25-foreman-supply-ledger-coordinate",
  "name": "RESTART 25：工头供纸账本坐标",
  "description": "工头交出的坐标不是地址，而是一串纸浆配比。塔内播音员说，只要按这串比例反向调频，就能找到决定死亡证明供给的账房。代价是那批污染证明纸会先抵达医院。",
  "triggers": [
    "restart-paper-factory-witness-filed"
  ],
  "consequences": [
    "restart-foreman-supply-ledger-coordinate-decoded"
  ],
  "conditions": [
    "flag.restart_foreman_witness_ledger_opened:1",
    "flag.restart_bargained_with_paper_foreman:1",
    "flag.restart_next_region_supply_ledger_route:1",
    "have.card:card-restart-worker-testimony",
    "have.card:card-restart-uncut-certificate-paper"
  ],
  "effects": [
    "set.flag:restart_foreman_supply_ledger_coordinate_decoded"
  ],
  "slots": [
    {
      "id": "slot-0",
      "name": "解码坐标的人",
      "cardType": "person"
    },
    {
      "id": "slot-1",
      "name": "污染批次样纸",
      "cardType": "item"
    }
  ],
  "options": [
    {
      "text": "立刻追踪账房坐标，抢在污染证明纸送回医院前接管供纸账本。",
      "effects": [
        {
          "type": "gain.influence",
          "amount": 9
        }
      ]
    },
    {
      "text": "放任污染证明纸先抵达医院，让旧日出医院的死亡证明集体失效。",
      "effects": [
        {
          "type": "gain.favor",
          "amount": 9
        }
      ]
    }
  ],
  "coinRewardTiers": [
    {
      "minValue": 0,
      "maxValue": 8,
      "rewards": [
        {
          "type": "gain.influence",
          "amount": 2
        }
      ],
      "description": "坐标解出半截。你知道账房存在，却还不知道它属于医院还是广播塔。"
    },
    {
      "minValue": 9,
      "maxValue": 14,
      "rewards": [
        {
          "type": "gain.favor",
          "amount": 4
        },
        {
          "type": "gain.influence",
          "amount": 4
        }
      ],
      "description": "未裁切证明纸显出账房门牌：所有死亡证明都从同一本供纸账里扣数。"
    },
    {
      "minValue": 15,
      "maxValue": 999,
      "rewards": [
        {
          "type": "gain.favor",
          "amount": 6
        },
        {
          "type": "gain.influence",
          "amount": 6
        }
      ],
      "description": "广播塔和纸厂同时沉默一秒。工头的坐标指向下一处核心：给死亡分配纸额的账房。"
    }
  ]
}

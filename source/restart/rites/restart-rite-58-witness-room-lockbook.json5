                }
        ]
      },
      {
        "text": "把听证案号牌夹进暗页，让林夕保留一份只有活人能读出的备份证词。",
        "effects": [
                {
                        "type": "gain.favor",
                        "amount": 27
                },
                {
                        "type": "set.flag",
                        "flag": "restart_linxi_kept_safehouse_dark_copy"
                }
        ]
      }
  ],
  "coinRewardTiers": [
    {"minValue": 0, "maxValue": 10, "rewards": [{"type": "gain.influence", "amount": 4}], "description": "路线勉强接上，但门外追索仍能听见脚步。"},
    {"minValue": 11, "maxValue": 16, "rewards": [{"type": "gain.favor", "amount": 5}, {"type": "gain.influence", "amount": 6}], "description": "保护屋把证词和追索拆开，下一步可以继续推进。"},
    {"minValue": 17, "maxValue": 999, "rewards": [{"type": "gain.favor", "amount": 8}, {"type": "gain.influence", "amount": 8}], "description": "证词获得院外回声。医院的旧路径开始找不到完整地址。"}

    "gain.card:card-restart-borrowed-pulse-lantern"
],
  "slots": [
    {"id": "slot-0", "name": "翻开锁账的人", "cardType": "person"},
    {"id": "slot-1", "name": "压住账页的公开名单或案号", "cardType": "item"}
  ],
  "options": [
      {
        "text": "把旁听名单钉进锁账簿，让保护屋承认公开听见过的名字不能再被医院收回。",

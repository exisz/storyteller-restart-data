{
  "id": "restart-event-32-receiving-living-alarm",
  "name": "第三十二回合事件：收货口活体警报",
  "description": "第七次日出的名字刚靠近签收单，收货口就响起活体警报：本批死亡证明纸不得由仍可呼吸者签收。塔内播音员的声音从医院喇叭里插进来，试图把“活人”改读成“待处理尸体”。",
  "trigger": {"turn": 32},
  "consequences": ["restart-receiving-living-alarm-answered"],
  "options": [
    {
      "text": "保护第七次日出的收货人姓名，让医院记录她作为活证人签收。",
      "effects": [
        "gain.influence:8",
        "set.flag:restart_receiving_living_alarm_answered",
        "set.flag:restart_seventh_sun_named_as_hospital_receiver"
      ]
    },
    {
      "text": "逼塔内播音员继续改口，把TA的活人声音绑进医院收货系统。",
      "effects": [
        "gain.favor:8",
        "set.flag:restart_receiving_living_alarm_answered",
        "set.flag:restart_operator_bound_to_hospital_intake_voice"
      ]
    }
  ]
}
